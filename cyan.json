{
    "name": "Dark Blue Hospital Dashboard",
    "dataColors": [
        "#4DA3FF",
        "#7FD1FF",
        "#3A86FF",
        "#2EC4B6",
        "#5E60CE",
        "#64DFDF",
        "#80FFDB",
        "#5390D9"
    ],
    "background": "#0B1F33",
    "foreground": "#EAF4FF",
    "tableAccent": "#4DA3FF",
    "visualStyles": {
        "*": {
            "*": {
                "background": [{
                    "show": true,
                    "color": { "solid": { "color": "#102A43" } },
                    "transparency": 0
                }],
                "border": [{
                    "show": true,
                    "color": { "solid": { "color": "#1F3B57" } },
                    "radius": 12
                }],
                "title": [{
                    "show": true,
                    "fontColor": { "solid": { "color": "#EAF4FF" } },
                    "fontSize": 13,
                    "fontFamily": "Segoe UI Semibold"
                }],
                "labels": [{
                    "color": { "solid": { "color": "#9FB3C8" } }
                }]
            }
        },
        "page": {
            "*": {
                "background": [{
                    "color": { "solid": { "color": "#0B1F33" } },
                    "transparency": 0
                }]
            }
        }
    }
}